<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 標題 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎵 音樂懸浮視窗"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="設定與控制"
            android:textSize="13sp"
            android:textColor="#88FFFFFF"
            android:layout_marginBottom="32dp" />

        <!-- 圓角設定卡片 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="懸浮視窗圓角設定"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <!-- 左上角 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↖ 左上角圓角"
                    android:textSize="15sp"
                    android:textColor="#DDFFFFFF" />

                <Switch
                    android:id="@+id/switchCornerTopLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#6200EE"
                    android:trackTint="#3700B3" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2AFFFFFF"
                android:layout_marginBottom="4dp" />

            <!-- 右上角 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↗ 右上角圓角"
                    android:textSize="15sp"
                    android:textColor="#DDFFFFFF" />

                <Switch
                    android:id="@+id/switchCornerTopRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#6200EE"
                    android:trackTint="#3700B3" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2AFFFFFF"
                android:layout_marginBottom="4dp" />

            <!-- 左下角 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↙ 左下角圓角"
                    android:textSize="15sp"
                    android:textColor="#DDFFFFFF" />

                <Switch
                    android:id="@+id/switchCornerBottomLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#6200EE"
                    android:trackTint="#3700B3" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2AFFFFFF"
                android:layout_marginBottom="4dp" />

            <!-- 右下角 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↘ 右下角圓角"
                    android:textSize="15sp"
                    android:textColor="#DDFFFFFF" />

                <Switch
                    android:id="@+id/switchCornerBottomRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#6200EE"
                    android:trackTint="#3700B3" />

            </LinearLayout>

        </LinearLayout>

        <!-- 文字對齊設定 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="其他設定"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="文字靠左顯示"
                    android:textSize="15sp"
                    android:textColor="#DDFFFFFF" />

                <Switch
                    android:id="@+id/switchTextAlignLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="#6200EE"
                    android:trackTint="#3700B3" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2AFFFFFF"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="12dp"/>

            <!-- 視窗大小滑桿 -->
            <TextView
                android:id="@+id/tvOverlaySizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="視窗大小"
                android:textSize="15sp"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="8dp" />
                
            <SeekBar
                android:id="@+id/seekOverlaySize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:progressTint="#6200EE"
                android:thumbTint="#6200EE" />

        </LinearLayout>

        <!-- 提示文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 圓角設定套用至懸浮視窗外框，預設右側兩角為圓角。"
            android:textSize="12sp"
            android:textColor="#88FFFFFF"
            android:layout_marginBottom="32dp" />

        <!-- 啟動按鈕 -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="啟動音樂懸浮視窗"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6200EE"
            android:layout_marginBottom="12dp" />

        <!-- 停止按鈕 -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="停止懸浮視窗"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B00020"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>